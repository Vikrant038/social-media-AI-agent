# Copy to .env and fill in your key (or use .streamlit/secrets.toml instead).
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional: work around YouTube IP bans on transcript fetches ---
# Recommended: Webshare residential proxies (https://www.webshare.io/).
# WEBSHARE_PROXY_USERNAME=your_webshare_username
# WEBSHARE_PROXY_PASSWORD=your_webshare_password
#
# Or any generic HTTP/HTTPS proxy:
# HTTP_PROXY_URL=http://user:pass@host:port
# HTTPS_PROXY_URL=http://user:pass@host:port
